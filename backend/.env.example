# Server
PORT=3001
FRONTEND_URL=http://localhost:3000

# Database (PostgreSQL)
DATABASE_URL=postgresql://postgres:postgres@localhost:5544/upwork_clone

# Admin seed (npm run seed-admin). Dacă ADMIN_PASSWORD lipsește, se generează una.
ADMIN_EMAIL=admin@aplica.md
# ADMIN_PASSWORD=
# ADMIN_FIRST=Admin
# ADMIN_LAST=aplica

# JWT - schimbă aceste secrete în producție!
JWT_ACCESS_SECRET=change-me-access-secret-please
JWT_ACCESS_TTL=15m
JWT_REFRESH_SECRET=change-me-refresh-secret-please
JWT_REFRESH_TTL=7d

# Email (SMTP). Dacă SMTP_HOST lipsește, în dev se folosește Ethereal (inbox de test).
# Exemple: Resend -> smtp.resend.com / 465 / SECURE=true / USER=resend / PASS=<api_key>
#          SES    -> email-smtp.<region>.amazonaws.com / 587 / user+pass din SES SMTP creds
MAIL_FROM=aplica <no-reply@aplica.md>
# SMTP_HOST=
# SMTP_PORT=587
# SMTP_SECURE=false
# SMTP_USER=
# SMTP_PASS=
